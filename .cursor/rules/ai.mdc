### 2. Category Suggester
**When**: Teacher is filling out the submission form and has typed a title + abstract
**Model**: `claude-sonnet-4-6`
**Where**: API route `app/api/ai/suggest-category/route.ts` (needs to be a route because it's called from a public page with no auth)
**Output**: Structured JSON `{ suggestedCategory: string, confidence: "high" | "medium" | "low", reason: string }`
**Shown to**: Teacher on the submission form as a suggestion they can accept or ignore

```ts
import { generateObject } from "ai"
import { z } from "zod"
import { FAST_MODEL } from "@/lib/ai"

export async function POST(req: Request) {
  const { title, abstract, categories } = await req.json()

  const { object } = await generateObject({
    model: FAST_MODEL,
    schema: z.object({
      suggestedCategory: z.string(),
      confidence: z.enum(["high", "medium", "low"]),
      reason: z.string(),
    }),
    prompt: `Given this science fair project, suggest the most appropriate category from the list provided.

Project Title: ${title}
Abstract: ${abstract}

Available categories: ${categories.join(", ")}

Return the best matching category name exactly as listed.`,
  })

  return Response.json(object)
}
```

