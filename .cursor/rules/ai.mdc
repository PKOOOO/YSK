### 1. Abstract Summarizer
**When**: Project is submitted by a teacher — runs automatically in the background after upload
**Model**: `claude-sonnet-4-6`
**Where**: Server Action in `app/actions/ai.ts`, triggered after `createProject()`
**Output**: 2-3 sentence plain English summary, stored in `Project.aiSummary`
**Shown to**: Judges on the scoring page above the full abstract

```ts
import { generateText } from "ai"
import { FAST_MODEL } from "@/lib/ai"
import { prisma } from "@/lib/prisma"

export async function generateAbstractSummary(projectId: string) {
  const project = await prisma.project.findUniqueOrThrow({
    where: { id: projectId },
    select: { title: true, abstract: true },
  })

  const { text } = await generateText({
    model: FAST_MODEL,
    prompt: `Summarize this science fair project abstract in 2-3 clear sentences for a judge who needs a quick overview. Be factual and concise.

Title: ${project.title}
Abstract: ${project.abstract}`,
  })

  await prisma.project.update({
    where: { id: projectId },
    data: { aiSummary: text },
  })

  return text
}
```

