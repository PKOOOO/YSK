### 3. Auto-Score Suggestions
**When**: Judge opens a project scoring page
**Model**: `claude-opus-4-6`
**Where**: API route `app/api/ai/score-suggestions/route.ts` (called client-side from the scoring page)
**Output**: Structured JSON with a suggested score per criterion and a brief justification
**Shown to**: Judge as a "AI Suggestion" panel — judge can accept each suggestion or ignore
**Important**: AI suggestions are NEVER auto-submitted — judge must manually move sliders

```ts
import { generateObject } from "ai"
import { z } from "zod"
import { SMART_MODEL } from "@/lib/ai"
import { auth } from "@clerk/nextjs/server"

export async function POST(req: Request) {
  const { userId } = auth()
  if (!userId) return new Response("Unauthorized", { status: 401 })

  const { projectTitle, abstract, criteria } = await req.json()
  // criteria = [{ id, name, description, maxScore }]

  const { object } = await generateObject({
    model: SMART_MODEL,
    schema: z.object({
      suggestions: z.array(z.object({
        criterionId: z.string(),
        suggestedScore: z.number(),
        justification: z.string().max(200),
      })),
      overallImpression: z.string().max(300),
    }),
    prompt: `You are assisting a science fair judge. Based on the project information below, suggest scores for each criterion.

Project: ${projectTitle}
Abstract: ${abstract}

Criteria (score each from 0 to their maxScore):
${criteria.map((c: { id: string; name: string; description: string; maxScore: number }) => `- ${c.name} (max ${c.maxScore}): ${c.description}`).join("\n")}

Be fair, objective, and base your scores strictly on what is written in the abstract. If information is insufficient to score a criterion confidently, suggest a mid-range score and note it in the justification.`,
  })

  return Response.json(object)
}
```

